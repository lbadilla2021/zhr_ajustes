<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="resource_calendar_tree_system_schedule" model="ir.ui.view">
        <field name="name">resource.calendar.tree.system.schedule</field>
        <field name="model">resource.calendar</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="system_schedule"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="resource_calendar_action_system_schedule" model="ir.actions.act_window">
        <field name="name">Sistemas Horario</field>
        <field name="res_model">resource.calendar</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="resource_calendar_form_inherit_system_schedule" model="ir.ui.view">
        <field name="name">resource.calendar.form.system.schedule</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="system_schedule"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_hr_resource_calendar"
              name="Sistemas Horario"
              parent="menu_hr_tables_root"
              action="resource_calendar_action_system_schedule"
              sequence="30"/>
</odoo>
