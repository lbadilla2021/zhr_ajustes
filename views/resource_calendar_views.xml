<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hr_system_schedule_tree" model="ir.ui.view">
        <field name="name">hr.system.schedule.tree</field>
        <field name="model">hr.system.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="hr_system_schedule_form" model="ir.ui.view">
        <field name="name">hr.system.schedule.form</field>
        <field name="model">hr.system.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_system_schedule_action" model="ir.actions.act_window">
        <field name="name">Sistemas Horario</field>
        <field name="res_model">hr.system.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_system_schedule"
              name="Sistemas Horario"
              parent="menu_hr_tables_root"
              action="hr_system_schedule_action"
              sequence="30"/>
</odoo>
