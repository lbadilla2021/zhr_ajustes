<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="hr_contract_form_inherit_print" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.print</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">

            <!-- Agregamos el botón en la cabecera -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_print_contract"
                    type="object"
                    string="Contrato"
                    icon="fa-print"
                    class="btn-primary btn-sm"
                    help="Imprime el contrato de trabajo del empleado"
                />
            </xpath>

            <xpath expr="//header" position="inside">
                <button
                    name="action_print_anexo_planta"
                    type="object"
                    string="Anexo Planta"
                    icon="fa-print"
                    class="btn-secondary btn-sm"
                    help="Imprime el anexo de planta del trabajador"
                />
            </xpath>

            <xpath expr="//header" position="inside">
                <button
                    name="action_print_pacto_he"
                    type="object"
                    string="Pacto HE"
                    icon="fa-print"
                    class="btn-secondary btn-sm"
                    help="Imprime el pacto de horas extraordinarias"/>
             </xpath>

            <xpath expr="//header" position="inside">
                <button
                    name="action_print_actualizacion"
                    type="object"
                    string="Actualización"
                    icon="fa-print"
                    class="btn-secondary btn-sm"
                    help="Imprime actualización de contrato"/>
            </xpath>

            <xpath expr="//field[@name='contract_type_id']" position="after">
                <field name="employee_payment_concept_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="payment_concept_id"/>
                        <field name="amount"/>
                    </list>
                </field>
            </xpath>
        </field>
    </record>

</odoo>
