<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Pestañas Previsión y Acreditaciones -->
    <!-- ========================= -->
    <record id="hr_employee_prevision_tab" model="ir.ui.view">
        <field name="name">hr.employee.prevision.tab</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Previsión" name="prevision">
                    <group>
                        <field name="afp_id"/>
                        <field name="health_system_id"/>
                    </group>
                </page>

                <page string="Acreditaciones" name="accreditations">
                    <field name="accreditation_ids">
                        <list editable="bottom">
                            <field name="accreditation_type_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="active"/>
                            <field name="attachment_id"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Botón Dar de Baja + Estado -->
    <!-- ========================= -->
    <record id="hr_employee_state_button" model="ir.ui.view">
        <field name="name">hr.employee.state.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">

                <!-- Botón visible SOLO si el estado es activo -->
                <button name="action_open_termination_wizard"
                        string="Dar de Baja"
                        type="object"
                        class="btn-danger"
                        modifiers="{'invisible': [('state', '=', 'inactive')]}"/>

                <!-- Statusbar del estado -->
                <field name="state"
                       widget="statusbar"
                       statusbar_visible="active,inactive"/>

            </xpath>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Sistema Horario en Información de trabajo -->
    <!-- ========================= -->
    <record id="hr_employee_system_schedule_work_info" model="ir.ui.view">
        <field name="name">hr.employee.system.schedule.work.info</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']//field[@name='resource_calendar_id']" position="after">
                <field name="system_schedule"/>
            </xpath>
        </field>
    </record>

</odoo>
