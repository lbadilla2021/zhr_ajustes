<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hr_employee_reactivation_wizard_view" model="ir.ui.view">
        <field name="name">hr.employee.reactivation.wizard.form</field>
        <field name="model">hr.employee.reactivation.wizard</field>
        <field name="arch" type="xml">
            <form string="Dar de Alta">
                <group>
                    <field name="employee_id" readonly="1"/>
                    <field name="fecha_ingreso" required="1"/>
                    <field name="fecha_salida"/>
                </group>
                <footer>
                    <button string="Confirmar" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
