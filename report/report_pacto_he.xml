<odoo>

    <record id="action_report_pacto_he" model="ir.actions.report">
        <field name="name">Pacto Horas Extraordinarias</field>
        <field name="model">hr.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">zhr_ajustes.report_pacto_he</field>
        <field name="report_file">zhr_ajustes.report_pacto_he</field>
        <field name="print_report_name">'Pacto HE - %s' % (object.employee_id.name)</field>
    </record>

    <template id="report_pacto_he">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">

                    <div class="page">

                        <h2>Pacto de Horas Extraordinarias</h2>

                        <p>
                            Trabajador:
                            <span t-esc="doc.employee_id.name"/>
                        </p>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>