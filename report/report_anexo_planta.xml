                                        R.U.T.: <span t-esc="contract.employee_id.identification_id or ''"/>
                                    </td>
                                    <td width="50%" style="text-align:center; border:none;">
                                        ___________________________<br/>
                                        Servicios Barca SPA.<br/>
                                        R.U.T.: 76.766.106 – 1
                                    </td>
                                </tr>
                            </table>

                </div>

    </t>
    </t>
    </t>
</template>
</odoo>