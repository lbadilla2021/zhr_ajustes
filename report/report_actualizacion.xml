<odoo>

    <record id="action_report_actualizacion" model="ir.actions.report">
        <field name="name">Actualización de Contrato</field>
        <field name="model">hr.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">zhr_ajustes.report_actualizacion</field>
        <field name="report_file">zhr_ajustes.report_actualizacion</field>
        <field name="print_report_name">'Actualizacion Contrato - %s' % (object.employee_id.name)</field>
    </record>


    <template id="report_actualizacion">
       
     <t t-call="web.html_container">
    <t t-foreach="docs" t-as="contract">
    <t t-call="web.external_layout">
        <div class="page">

            <p>Actualización Contrato</p>

            <p>
                Trabajador:
                <span t-esc="contract.employee_id.name"/>
            </p>

        </div>
    </t>
    </t>
    </t>
</template>

</odoo>