<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="employee_add_dates" model="ir.ui.view">
        <field name="name">employee.add.dates</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Inserta Fechas Laborales en Work Information -->
            <xpath expr="//page[@name='public']//div[@id='o_work_employee_main']" position="inside">
                <group string="Fechas Laborales">
                    <field name="first_contract_date" string="Fecha de Ingreso"/>
                    <field name="departure_date" string="Fecha de Salida"/>
                </group>
            </xpath>

        </field>
    </record>

    <record id="employee_add_name_fields" model="ir.ui.view">
        <field name="name">employee.add.name.fields</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='mobile_phone']/ancestor::group[1]" position="before">
                <group string="Nombre">
                    <field name="apellido_paterno"/>
                    <field name="apellido_materno"/>
                    <field name="nombres"/>
                    <field name="nombre_preferido"/>
                </group>
            </xpath>

        </field>
    </record>

    <record id="employee_add_cost_center" model="ir.ui.view">
        <field name="name">employee.add.cost.center</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='job_id']" position="after">
                <field name="analytic_account_id"/>
            </xpath>

        </field>
    </record>
</odoo>
